# Google OAuth Client ID (демо-ключ для разработки)
# Замените на свой ключ с https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=demo-client-id.apps.googleusercontent.com

# Firebase (для SMS авторизации)
# Получите на https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
